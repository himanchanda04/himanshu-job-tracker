# ─── SERVER (.env inside server/) ────────────────────────────────────────────

# Port the Express server listens on (Railway overrides this automatically)
PORT=3001

# Secret key for signing JWT tokens — CHANGE THIS in production!
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-me-to-a-random-string

# ─── CLIENT (.env.local inside client/) ──────────────────────────────────────

# Leave empty during local development — Vite proxy handles /api → localhost:3001
# In production (Vercel), set this to your Railway backend URL:
#   VITE_API_URL=https://your-app.railway.app
VITE_API_URL=
